{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MCP Tool Call Request",
    "description": "Request to execute a tool",
    "type": "object",
    "properties": {
        "jsonrpc": {
            "type": "string",
            "const": "2.0"
        },
        "method": {
            "type": "string",
            "const": "tool.call"
        },
        "id": {
            "type": "string",
            "description": "Unique request identifier"
        },
        "params": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Tool name to call"
                },
                "arguments": {
                    "type": "object",
                    "description": "Tool-specific arguments"
                },
                "context": {
                    "type": "object",
                    "description": "Optional context information",
                    "properties": {
                        "sessionId": {
                            "type": "string"
                        },
                        "origin": {
                            "type": "string",
                            "enum": [
                                "voice",
                                "ui",
                                "system",
                                "api"
                            ]
                        }
                    }
                }
            },
            "required": [
                "name",
                "arguments"
            ]
        }
    },
    "required": [
        "jsonrpc",
        "method",
        "id",
        "params"
    ]
}