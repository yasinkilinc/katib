            ],
            "requires_approval": true,
            "rollback_required": false,
            "parameter_mapping": {
                "file": "SCRIPT_PATH"
            }
        }
    },
    "forbidden_mappings": [
        {
            "pattern": "recursive_delete",
            "reason": "Too destructive for automated terminal agent"
        },
        {
            "pattern": "system_update",
            "reason": "OS level changes forbidden"
        },
        {
            "pattern": "ssh_remote",
            "reason": "Lateral movement forbidden"
        }
    ],
    "failure_codes": {
        "mapping_not_found": "PLAN_STEP_UNKNOWN",
        "risk_too_high": "APPROVAL_REQUIRED_BUT_MISSING",
        "parameter_mismatch": "INVALID_ARGUMENTS",
